/*
Задача 5. Кооперативная блокировка

Программа A (блокиратор):
- Открывает файл lock_test.txt на чтение и запись (O_RDWR).
- Устанавливает исключительную блокировку на весь файл с помощью fcntl() (F_SETLKW).
- Удерживает блокировку 15 секунд, затем снимает её.
- Записывает в консоль свои действия.
*/



#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>

int main() {
    int fd = open("lock_test.txt", O_RDWR | O_CREAT, 0644);
    if (fd == -1) {
        perror("open");
        exit(1);
    }

    struct flock fl;
    fl.l_type = F_WRLCK;
    fl.l_whence = SEEK_SET;
    fl.l_start = 0;
    fl.l_len = 0;

    if (fcntl(fd, F_SETLKW, &fl) == -1) {
        perror("fcntl lock");
        close(fd);
        exit(1);
    }

    printf("Блокировка установлена (PID=%d)\n", getpid());
    sleep(15);

    fl.l_type = F_UNLCK;
    if (fcntl(fd, F_SETLK, &fl) == -1) {
        perror("fcntl unlock");
        close(fd);
        exit(1);
    }

    printf("Блокировка снята\n");
    close(fd);
    return 0;
}
